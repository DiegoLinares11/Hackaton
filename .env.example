# Backend API keys — set ONE of these options:

# Option A: KnowledgeXpert (uses E4C KnowledgeBases directly — preferred for E4C alignment)
KNOWLEDGEXPERT_API_URL=https://knowledgexpert.bearcreek.com
KNOWLEDGEXPERT_API_KEY=your-key-here

# Option B: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option C: OpenAI (gpt-4o-mini by default; override OPENAI_MODEL to any other chat model)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Option D: Demo mode — don't set any keys (uses keyword matching fallback)

# Frontend
VITE_API_URL=http://localhost:8000
